SERVER_HOST=127.0.0.1
SERVER_PORT=4000
SQLITE_PATH=apps/server/data/open-science.sqlite
LOG_DIR=logs/server
MIGRATION_DIR=apps/server/src/db/migrations
LOG_LEVEL=info

AGENT_DEFAULT_CWD=/absolute/path/to/workspace
AGENT_DEFAULT_RUNTIME_MODE=full_access

CODEX_BINARY_PATH=codex
CODEX_HOME=
CODEX_DEFAULT_MODEL=
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX=danger-full-access

CLAUDE_CODE_BINARY_PATH=
CLAUDE_CONFIG_DIR=
CLAUDE_DEFAULT_MODEL=
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_ALLOW_DANGEROUSLY_SKIP_PERMISSIONS=true
