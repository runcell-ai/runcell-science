{
  "name": "@open-science/science-connectors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "open-science-science-connector": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "import": "./dist/registry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
